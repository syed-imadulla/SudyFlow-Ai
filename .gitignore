# ──────────────────────────────────────────────
# StudyFlow Ai — Monorepo Root .gitignore
# ──────────────────────────────────────────────

# Dependencies (both frontend & backend)
**/node_modules/

# Environment variables (never commit secrets)
**/.env
**/.env.local
**/.env.*.local

# Build output
dist/
build/

# Logs
*.log
**/logs/

# OS artefacts
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
